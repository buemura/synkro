{
  "name": "@synkro/nestjs",
  "version": "0.1.2",
  "description": "NestJS integration module for @synkro/core",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "workflow",
    "state-machine",
    "orchestrator",
    "event-driven",
    "redis"
  ],
  "author": "buemura",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/buemura/synkro.git"
  },
  "homepage": "https://github.com/buemura/synkro/packages/nestjs#readme",
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@synkro/core": "^0.5.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@synkro/core": "file:../core",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.7.0"
  }
}
