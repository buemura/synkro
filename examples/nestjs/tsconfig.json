{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "./dist",
    "module": "es2022",
    "moduleResolution": "bundler",
    "target": "es2022",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
