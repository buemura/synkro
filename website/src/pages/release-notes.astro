---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import fs from "node:fs";
import path from "node:path";

interface ChangelogEntry {
  version: string;
  date: string;
  sections: { heading: string; items: string[] }[];
}

interface PackageChangelog {
  name: string;
  entries: ChangelogEntry[];
}

function parseChangelog(content: string): ChangelogEntry[] {
  const entries: ChangelogEntry[] = [];
  const lines = content.split("\n");

  let current: ChangelogEntry | null = null;
  let currentSection: { heading: string; items: string[] } | null = null;

  for (const line of lines) {
    // Match version headers: ## [0.18.1] - 2026-03-11
    const versionMatch = line.match(
      /^## \[(\d+\.\d+\.\d+)\]\s*-\s*(\d{4}-\d{2}-\d{2})/
    );
    if (versionMatch) {
      if (current) entries.push(current);
      current = {
        version: versionMatch[1],
        date: versionMatch[2],
        sections: [],
      };
      currentSection = null;
      continue;
    }

    // Skip [Unreleased]
    if (line.startsWith("## [Unreleased]")) continue;

    // Match section headers: ### Added, ### Fixed, etc.
    const sectionMatch = line.match(/^### (.+)/);
    if (sectionMatch && current) {
      currentSection = { heading: sectionMatch[1], items: [] };
      current.sections.push(currentSection);
      continue;
    }

    // Match list items
    if (line.startsWith("- ") && currentSection) {
      currentSection.items.push(line.slice(2));
    }
  }

  if (current) entries.push(current);
  return entries;
}

const packages = [
  { dir: "core", name: "@synkro/core" },
  { dir: "ui", name: "@synkro/ui" },
  { dir: "agents", name: "@synkro/agents" },
  { dir: "nestjs", name: "@synkro/nestjs" },
  { dir: "next", name: "@synkro/next" },
];

const changelogs: PackageChangelog[] = [];

for (const pkg of packages) {
  const filePath = path.resolve(
    process.cwd(),
    "..",
    "packages",
    pkg.dir,
    "CHANGELOG.md"
  );
  try {
    const content = fs.readFileSync(filePath, "utf-8");
    const entries = parseChangelog(content);
    if (entries.length > 0) {
      changelogs.push({ name: pkg.name, entries });
    }
  } catch {
    // Skip missing changelogs
  }
}

// Build a unified timeline: group all releases by date
interface TimelineEntry {
  date: string;
  releases: { name: string; version: string; sections: ChangelogEntry["sections"] }[];
}

const dateMap = new Map<string, TimelineEntry>();

for (const pkg of changelogs) {
  for (const entry of pkg.entries) {
    if (!dateMap.has(entry.date)) {
      dateMap.set(entry.date, { date: entry.date, releases: [] });
    }
    dateMap.get(entry.date)!.releases.push({
      name: pkg.name,
      version: entry.version,
      sections: entry.sections,
    });
  }
}

const timeline = [...dateMap.values()].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);

function formatDate(dateStr: string): string {
  return new Date(dateStr + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}

function slugify(text: string): string {
  return text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "");
}

const sectionIcons: Record<string, string> = {
  Added: "✦",
  Fixed: "✔",
  Changed: "↻",
  Removed: "✕",
  Verified: "✓",
};
---

<StarlightPage
  frontmatter={{
    title: "Release Notes",
    description: "Changelog and release history for all Synkro packages",
    tableOfContents: { minHeadingLevel: 2, maxHeadingLevel: 2 },
  }}
>
  <p class="release-notes-intro">
    All notable changes to Synkro packages, organized by release date.
  </p>

  {timeline.map((day) => (
    <div class="timeline-day">
      <h2 id={slugify(day.date)}>{formatDate(day.date)}</h2>

      <div class="releases-grid">
        {day.releases.map((release) => (
          <div class="release-card">
            <div class="release-header">
              <span class="package-name">{release.name}</span>
              <span class="version-badge">v{release.version}</span>
            </div>

            {release.sections.map((section) => (
              <div class="release-section">
                <h4 class="section-heading">
                  <span class="section-icon">
                    {sectionIcons[section.heading] || "•"}
                  </span>
                  {section.heading}
                </h4>
                <ul class="change-list">
                  {section.items.map((item) => (
                    <li set:html={item
                      .replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")
                      .replace(/`(.+?)`/g, "<code>$1</code>")
                    } />
                  ))}
                </ul>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>
  ))}
</StarlightPage>

<style>
  .release-notes-intro {
    color: var(--sl-color-gray-2);
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .timeline-day {
    margin-bottom: 2.5rem;
  }

  .releases-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .release-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    background: var(--sl-color-bg-nav);
    transition: border-color 0.2s;
  }

  .release-card:hover {
    border-color: var(--sl-color-accent);
  }

  .release-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .package-name {
    font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
    font-weight: 600;
    font-size: 1rem;
    color: var(--sl-color-white);
  }

  .version-badge {
    font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
    font-size: 0.8rem;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    background: var(--sl-color-accent-low);
    color: var(--sl-color-accent-high);
    font-weight: 500;
  }

  .release-section {
    margin-bottom: 0.75rem;
  }

  .release-section:last-child {
    margin-bottom: 0;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-2);
    margin: 0 0 0.4rem 0;
  }

  .section-icon {
    font-size: 0.75rem;
    color: var(--sl-color-accent);
  }

  .change-list {
    margin: 0;
    padding-left: 1.25rem;
    list-style: none;
  }

  .change-list li {
    position: relative;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin-bottom: 0.3rem;
  }

  .change-list li::before {
    content: "–";
    position: absolute;
    left: -1rem;
    color: var(--sl-color-gray-4);
  }

  .change-list li :global(strong) {
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .change-list li :global(code) {
    font-family: var(--sl-font-mono, "JetBrains Mono", monospace);
    font-size: 0.82em;
    padding: 0.1em 0.35em;
    border-radius: 0.25rem;
    background: var(--sl-color-gray-6);
    color: var(--sl-color-accent-high);
  }
</style>
